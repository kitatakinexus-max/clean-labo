                        </div>
                        <div class="col-md-6">
                            <select class="form-select" name="analysis_type">
                                <option value="" selected disabled>Type d'analyse</option>
                                <option value="complete">Analyse complète</option>
                                <option value="rapide">Analyse rapide</option>
                                <option value="expert">Analyse expert</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <textarea class="form-control" rows="4" placeholder="Description du problème ou objectif de l'analyse..." name="message"></textarea>
                        </div>
                    </div>
                    <div class="mt-4 text-center">
                        <button type="submit" class="btn btn-info btn-lg px-5">
                            <i class="bi bi-send me-2"></i>Demander Analyse
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
