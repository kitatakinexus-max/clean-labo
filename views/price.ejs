<%- include('partials/header', { meta: typeof meta !=='undefined' && meta ? meta : { title: typeof t !=='undefined' && t.seo ? t.seo.priceTitle : 'Tarifs Nettoyage Billets | Devis Gratuit - Clean Laboratoire' , description: typeof t !=='undefined' && t.seo ? t.seo.priceDescription : "Consultez nos tarifs pour le nettoyage et décapage de billets de banque sécurisé. Devis gratuits et solutions sur mesure Europe & Afrique." , keywords: 'tarifs nettoyage billets, prix solution SSD, devis décapage, coût laboratoire billets' , canonical: '/tarifs-solutions-nettoyage-billets' , robots: 'index, follow' } }) %>

    <!-- Pricing Plan Start -->
    <div class="container-fluid py-5">
        <div class="container">
            <div class="text-center mx-auto mb-5" style="max-width: 500px;">
                <h5 class="d-inline-block text-primary text-uppercase border-bottom border-5">
                    <%= typeof t !=='undefined' && t.price ? t.price.badge : 'Nos Tarifs' %>
                </h5>
                <h1 class="display-4">
                    <%= typeof t !=='undefined' && t.price ? t.price.title : 'Solutions sur Mesure' %>
                </h1>
            </div>
            <div class="owl-carousel price-carousel position-relative" style="padding: 0 45px 45px 45px;">
