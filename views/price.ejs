                <div class="bg-light rounded text-center">
                    <div class="position-relative">
                        <img class="img-fluid rounded-top" src="<%= getAsset('/img/price-1.jpg') %>" alt="Solution nettoyage billets standard">
                        <div class="position-absolute w-100 h-100 top-50 start-50 translate-middle rounded-top d-flex flex-column align-items-center justify-content-center" style="background: rgba(29, 42, 77, .8);">
                            <h3 class="text-primary"><%= typeof t !=='undefined' && t.price ? t.price.package1Title : 'Nettoyage Standard' %></h3>
                            <h2 class="display-4 text-white mb-0">
                                <small class="align-top fw-normal" style="font-size: 22px; line-height: 45px;">€</small><%= typeof t !=='undefined' && t.price ? t.price.package1Price : 'Sur' %><small class="align-bottom fw-normal" style="font-size: 16px; line-height: 40px;"> Devis</small>
                            </h2>
                        </div>
                    </div>
                    <div class="text-center py-5">
                        <p><%= typeof t !=='undefined' && t.price ? t.price.feature1 : 'Nettoyage sécurisé' %></p>
                        <p><%= typeof t !=='undefined' && t.price ? t.price.feature2 : 'Experts qualifiés' %></p>
                        <p><%= typeof t !=='undefined' && t.price ? t.price.feature3 : 'Résultats garantis' %></p>
                        <p><%= typeof t !=='undefined' && t.price ? t.price.feature4 : 'Service 24/7' %></p>
                        <a href="/contact?lang=<%= currentLang %>" class="btn btn-primary rounded-pill py-3 px-5 my-2"><%= typeof t !=='undefined' && t.price ? t.price.apply : 'Demander' %></a>
                    </div>
                </div>
                <!-- Pack 2 -->
                <div class="bg-light rounded text-center">
                    <div class="position-relative">
                        <img class="img-fluid rounded-top" src="<%= getAsset('/img/price-2.jpg') %>" alt="Solution décapage haute performance">
                        <div class="position-absolute w-100 h-100 top-50 start-50 translate-middle rounded-top d-flex flex-column align-items-center justify-content-center" style="background: rgba(29, 42, 77, .8);">
                            <h3 class="text-primary"><%= typeof t !=='undefined' && t.price ? t.price.package2Title : 'Pack Premium' %></h3>
                            <h2 class="display-4 text-white mb-0">
                                <small class="align-top fw-normal" style="font-size: 22px; line-height: 45px;">€</small><%= typeof t !=='undefined' && t.price ? t.price.package2Price : 'Sur' %><small class="align-bottom fw-normal" style="font-size: 16px; line-height: 40px;"> Devis</small>
                            </h2>
                        </div>
                    </div>
                    <div class="text-center py-5">
                        <p><%= typeof t !=='undefined' && t.price ? t.price.feature1 : 'Nettoyage sécurisé' %></p>
                        <p><%= typeof t !=='undefined' && t.price ? t.price.feature2 : 'Experts qualifiés' %></p>
                        <p><%= typeof t !=='undefined' && t.price ? t.price.feature3 : 'Résultats garantis' %></p>
                        <p><%= typeof t !=='undefined' && t.price ? t.price.feature4 : 'Service 24/7' %></p>
                        <a href="/contact?lang=<%= currentLang %>" class="btn btn-primary rounded-pill py-3 px-5 my-2"><%= typeof t !=='undefined' && t.price ? t.price.apply : 'Demander' %></a>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Pricing Plan End -->

    <!-- Consultation Quick Start -->
    <div class="container-fluid bg-primary my-5 py-5">
        <div class="container py-5">
            <div class="row gx-5">
                <div class="col-lg-6 mb-5 mb-lg-0">
                    <div class="mb-4">
                        <h5 class="d-inline-block text-white text-uppercase border-bottom border-5"><%= typeof t !=='undefined' && t.consultation ? t.consultation.title : 'Expertise' %></h5>
                        <h2 class="display-4 text-white"><%= typeof t !=='undefined' && t.consultation ? t.consultation.subtitle : 'Analyse Gratuite de Vos Besoins' %></h2>
                    </div>
                    <p class="text-white mb-5"><%= typeof t !=='undefined' && t.service ? t.service.description1 : 'Nos experts vous accompagnent dans le choix de la solution la mieux adaptée à votre situation.' %></p>
                    <a class="btn btn-dark rounded-pill py-3 px-5 me-3" href="/contact?lang=<%= currentLang %>"><%= typeof t !=='undefined' && t.common ? t.common.contactUs : 'Contact' %></a>
                </div>
            </div>
        </div>
    </div>

<%- include('partials/footer') %>