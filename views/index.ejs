                            <i class="fab fa-facebook-f"></i>
                        </a>
                        
                        <a class="btn btn-outline-primary btn-square border-2 me-2" href="#!">
                            <i class="fab fa-instagram"></i>
                        </a>
                        
                    </div>
                        </div>
                        <div class="col-sm-6">
                            <h6 class="mb-3">
                                <i class="fa fa-check text-primary me-2"></i><%= typeof t !== 'undefined' && t.about ? t.about.check3 : '24/7 Support' %>
                            </h6>
                           
                        </div>
                    </div>
                    
                </div>
            </div>
