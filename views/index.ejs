<%- include('partials/header') %>

    <!-- Hero Start -->
    <div class="container-fluid pb-5 hero-header bg-light mb-5">
        <div class="container py-5">
            <div class="row g-5 align-items-center mb-5">
                <div class="col-lg-6">
                    <h1 class="display-1 mb-4 animated slideInRight">
                        <%= typeof t !== 'undefined' && t.hero ? t.hero.title : 'Creative' %> 
                        <span class="text-primary"><%= typeof t !== 'undefined' && t.hero ? t.hero.titleHighlight : 'Interior' %></span> 
                        <%= typeof t !== 'undefined' && t.hero ? t.hero.titleEnd : 'Design' %>
                    </h1>
                    <h5 class="d-inline-block border border-2 border-white py-3 px-5 mb-0 animated slideInRight">
                        <%= typeof t !== 'undefined' && t.hero ? t.hero.subtitle : 'Transforming spaces into beautiful experiences' %>
                    </h5>
                </div>
                <div class="col-lg-6">
                    <div class="owl-carousel header-carousel animated fadeIn">
                        <img class="img-fluid" src="<%= getAsset('/img/slider-1.png') %>" loading="lazy" alt="Analyse spectrophotométrique de billets dans notre laboratoire">
                        <img class="img-fluid" src="<%= getAsset('/img/slider-2.png') %>" loading="lazy" alt="SSD, poudre d'activation pour le décapage des billets de banque">
                        <img class="img-fluid" src="<%= getAsset('/img/slider-3.png') %>" loading="lazy" alt="solution pour nettoyer vos billets de banque">
                        <img class="img-fluid" src="<%= getAsset('/img/slider-4.png') %>" loading="lazy" alt="machine de nettoyage de billets de banque">
                    </div>
                </div>
            </div>
            <div class="row g-5 animated fadeIn">
                <div class="col-md-6 col-lg-3">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0 btn-square border border-2 border-white me-3">
                            <i class="fa fa-couch text-primary"></i>
                        </div>
                        <h5 class="lh-base mb-0"><%= typeof t !== 'undefined' && t.hero ? t.hero.feature1 : 'Modern Furniture' %></h5>
                    </div>
                </div>
                <div class="col-md-6 col-lg-3">
