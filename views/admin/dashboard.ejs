                                                                    data-lang="<%= lang %>" data-panel="<%= panel %>"
                                                                    value="<%= getNestedValue(siteContent[lang], field.key) %>">
                                                                <% } %>
                                                    </div>
                                                    <% }); %>
                                            </div>
                                        </div>
                                        <div class="card-footer">
