<style>
.product-card {
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
}

.product-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
    transition: left 0.5s;
}

.product-card:hover::before {
    left: 100%;
}

.product-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 15px 40px rgba(0,0,0,0.15) !important;
}

.product-badge {
    font-size: 0.7rem;
    font-weight: bold;
}

.benefit-icon {
    width: 40px;
    height: 40px;
    flex-shrink: 0;
}

.step-number {
    width: 60px;
    height: 60px;
    font-size: 1.2rem;
    font-weight: bold;
}

.guide-step {
    transition: transform 0.3s ease;
}

.guide-step:hover {
    transform: scale(1.05);
}

.promo-card {
    border: 2px dashed var(--bs-success);
}

.product-select-card {
    transition: border-color 0.3s ease;
}

.product-select-card:has(input:checked) {
    border-color: var(--bs-success);
    background-color: rgba(25, 135, 84, 0.05);
}

/* Animation poudre */
@keyframes powderFall {
    0% { transform: translateY(-10px); opacity: 0; }
    100% { transform: translateY(0); opacity: 1; }
}

.animate-powder-fall {
    animation: powderFall 0.6s ease-out;
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Animation des produits
    const productCards = document.querySelectorAll('.product-card');
    productCards.forEach((card, index) => {
        card.style.animationDelay = `${index * 0.1}s`;
        card.classList.add('animate-powder-fall');
    });

    // Gestion vidéo poudre
    const powderVideo = document.getElementById('powderVideo');
    if (powderVideo) {
        powderVideo.addEventListener('play', function() {
            console.log('Video utilisation poudres started');
        });
    }

    // Gestion formulaire commande
    const productCheckboxes = document.querySelectorAll('input[name="products[]"]');
    productCheckboxes.forEach(checkbox => {
        checkbox.addEventListener('change', function() {
            const quantityInput = this.parentElement.querySelector('input[type="number"]');
            if (this.checked) {
                quantityInput.required = true;
                quantityInput.disabled = false;
            } else {
                quantityInput.required = false;
                quantityInput.disabled = true;
                quantityInput.value = '';
            }
        });
    });

    // Animation au scroll
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.style.animationPlayState = 'running';
            }
        });
    }, { threshold: 0.1 });

    document.querySelectorAll('.animate-scale-in, .animate-fade-in-up, .animate-slide-in-left').forEach(el => {
        observer.observe(el);
    });
});
</script>

    <!-- Toastify -->
    <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
    <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/toastify-js"></script>

    <script>
    document.getElementById('poudreModalForm').addEventListener('submit', async function(e) {
        e.preventDefault();
        const btn = this.querySelector('[type="submit"]');
        btn.disabled = true;
        const body = new URLSearchParams(new FormData(this)).toString();
        try {
            const res = await fetch('/contact/send', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'Accept': 'application/json' },
                body: body
            });
            const json = await res.json();
            if (json.success) {
                Toastify({ text: '✅ Votre commande a bien été envoyée ! Nous vous répondrons rapidement.', duration: 5000, gravity: 'top', position: 'right', style: { background: 'linear-gradient(135deg, #198754, #157347)', borderRadius: '10px', fontWeight: '600' } }).showToast();
                this.reset();
                const modal = bootstrap.Modal.getInstance(document.getElementById('poudreModal'));
                if (modal) modal.hide();
            } else { throw new Error(); }
        } catch {
            Toastify({ text: '❌ Une erreur est survenue. Veuillez réessayer.', duration: 5000, gravity: 'top', position: 'right', style: { background: 'linear-gradient(135deg, #dc3545, #b02a37)', borderRadius: '10px', fontWeight: '600' } }).showToast();
        } finally {
            btn.disabled = false;
        }
    });
    </script>

