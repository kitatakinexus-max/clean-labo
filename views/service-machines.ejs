<!-- Modal Location -->
<div class="modal fade" id="locationModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title">Demande de Location Machine</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="locationModalForm">
                    <input type="hidden" name="service" value="location-machines">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <input type="text" class="form-control" placeholder="Votre Nom" name="name" required>
                        </div>
                        <div class="col-md-6">
                            <input type="email" class="form-control" placeholder="Votre Email" name="email" required>
                        </div>
                        <div class="col-md-6">
                            <input type="tel" class="form-control" placeholder="Téléphone" name="phone" required>
                        </div>
                        <div class="col-md-6">
                            <select class="form-select" name="machine_type" required>
                                <option value="" selected disabled>Type de machine</option>
                                <option value="decap-pro-5000">Décap'Pro 5000</option>
                                <option value="ultra-clean-8000">UltraClean 8000</option>
                                <option value="autre">Autre demande</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <select class="form-select" name="duration" required>
                                <option value="" selected disabled>Durée location</option>
                                <option value="1-semaine">1 semaine</option>
                                <option value="2-semaines">2 semaines</option>
                                <option value="1-mois">1 mois</option>
                                <option value="3-mois">3 mois</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <input type="number" class="form-control" placeholder="Volume estimé (billets/jour)" name="volume" required>
                        </div>
                        <div class="col-12">
                            <textarea class="form-control" rows="4" placeholder="Informations complémentaires..." name="message"></textarea>
                        </div>
                    </div>
                    <div class="mt-4 text-center">
                        <button type="submit" class="btn btn-success btn-lg px-5">
                            <i class="bi bi-send me-2"></i>Demander Location
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
.machine-card {
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border: 2px solid transparent;
}

.machine-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 15px 40px rgba(0,0,0,0.15) !important;
    border-color: var(--bs-success);
}

.benefit-icon {
    width: 70px;
    height: 70px;
}

.training-step {
    padding: 1rem;
    background: #f8f9fa;
    border-radius: 0.5rem;
    transition: transform 0.3s ease;
}

.training-step:hover {
    transform: translateX(10px);
}

.step-icon {
    width: 40px;
    height: 40px;
}

.price-tag {
    border: 2px dashed var(--bs-success);
}

/* Animations spécifiques machines */
@keyframes machineGlow {
    0% { box-shadow: 0 0 5px rgba(25, 135, 84, 0.5); }
    50% { box-shadow: 0 0 20px rgba(25, 135, 84, 0.8); }
    100% { box-shadow: 0 0 5px rgba(25, 135, 84, 0.5); }
}

.animate-machine-glow {
    animation: machineGlow 2s infinite;
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Animation des cartes machines au survol
    const machineCards = document.querySelectorAll('.machine-card');
    machineCards.forEach(card => {
        card.addEventListener('mouseenter', function() {
            this.classList.add('animate-machine-glow');
        });
        card.addEventListener('mouseleave', function() {
            this.classList.remove('animate-machine-glow');
        });
    });

    // Gestion vidéo machine
    const machineVideo = document.getElementById('machineVideo');
    if (machineVideo) {
        machineVideo.addEventListener('play', function() {
            console.log('Video machine démonstration started');
        });
    }

    // Animation au scroll
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.style.animationPlayState = 'running';
            }
        });
    }, { threshold: 0.1 });

    document.querySelectorAll('.animate-scale-in, .animate-fade-in-up, .animate-slide-in-left').forEach(el => {
        observer.observe(el);
    });
});
</script>

    <!-- Toastify -->
    <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
    <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/toastify-js"></script>

    <script>
    document.getElementById('locationModalForm').addEventListener('submit', async function(e) {
        e.preventDefault();
        const btn = this.querySelector('[type="submit"]');
        btn.disabled = true;
        const body = new URLSearchParams(new FormData(this)).toString();
        try {
            const res = await fetch('/contact/send', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'Accept': 'application/json' },
                body: body
            });
            const json = await res.json();
            if (json.success) {
                Toastify({ text: '✅ Votre demande de location a bien été envoyée ! Nous vous répondrons rapidement.', duration: 5000, gravity: 'top', position: 'right', style: { background: 'linear-gradient(135deg, #198754, #157347)', borderRadius: '10px', fontWeight: '600' } }).showToast();
                this.reset();
                const modal = bootstrap.Modal.getInstance(document.getElementById('locationModal'));
                if (modal) modal.hide();
            } else { throw new Error(); }
        } catch {
            Toastify({ text: '❌ Une erreur est survenue. Veuillez réessayer.', duration: 5000, gravity: 'top', position: 'right', style: { background: 'linear-gradient(135deg, #dc3545, #b02a37)', borderRadius: '10px', fontWeight: '600' } }).showToast();
        } finally {
            btn.disabled = false;
        }
    });
    </script>

