<%- include('partials/header', {
    meta: meta || {
        title: 'Contact Clean Laboratoire | Devis Gratuit Nettoyage Billets - Expert Europe Afrique',
        description: 'Contactez Clean Laboratoire pour un devis gratuit. Expert en nettoyage de billets, solutions SSD, décapage sécurisé. Europe et Afrique.',
        keywords: 'contact clean lab, devis nettoyage billets, expert SSD, laboratoire contact, consultation gratuite',
        canonical: '/contact-laboratoire-nettoyage',
        robots: 'index, follow'
    }
}) %>

    <!-- Contact Start -->
    <div class="container-fluid py-5">
        <div class="container py-5">
            <div class="text-center wow fadeIn" data-wow-delay="0.1s">
                <h1 class="mb-5">
                    <%= typeof t !== 'undefined' && t.contact ? t.contact.title : 'Une Question ?' %> 
                    <span class="text-uppercase text-primary bg-light px-2">
                        <%= typeof t !== 'undefined' && t.contact ? t.contact.titleHighlight : 'Contactez-Nous' %>
                    </span>
                </h1>
            </div>
            <div class="row justify-content-center">
                <div class="col-lg-7">
                    <p class="text-center mb-4">
                        <%= typeof t !== 'undefined' && t.contact ? t.contact.description : 'Notre équipe d\'experts est à votre écoute pour répondre à toutes vos questions concernant le nettoyage et la restauration de billets. Obtenez une consultation gratuite et personnalisée.' %>
                    </p>
                    
                    <!-- Informations de contact -->
                    <div class="row mb-5">
                        <div class="col-md-4 text-center mb-3">
                            <div class="contact-info bg-light rounded p-4">
                                <i class="fa fa-2x fa-phone text-primary mb-3"></i>
                                <h5><%= typeof t !== 'undefined' && t.contact ? t.contact.phone : 'Téléphone' %></h5>
                                <p class="mb-0"><%= companyInfo.phone %></p>
                            </div>
                        </div>
                        <div class="col-md-4 text-center mb-3">
                            <div class="contact-info bg-light rounded p-4">
                                <i class="fa fa-2x fa-phone text-primary mb-3"></i>
                                <h5><%= typeof t !== 'undefined' && t.contact ? t.contact.phone : 'Téléphone' %></h5>
                                <p class="mb-0"><%= companyInfo.phone %></p>
                            </div>
                        </div>

                        <div class="col-md-4 text-center mb-3">
                            <div class="contact-info bg-light rounded p-4">
                                <i class="fa fa-2x fa-phone text-primary mb-3"></i>
                                <h5><%= typeof t !== 'undefined' && t.contact ? t.contact.phone : 'Téléphone' %></h5>
                                <p class="mb-0"><%= companyInfo.phone %></p>
                            </div>
                        </div>
                        <div class="col-md-4 text-center mb-3">
                            <div class="contact-info bg-light rounded p-4">
                                <i class="fa fa-2x fa-phone text-primary mb-3"></i>
                                <h5><%= typeof t !== 'undefined' && t.contact ? t.contact.phone : 'Téléphone' %></h5>
                                <p class="mb-0"><%= companyInfo.phone %></p>
                            </div>
                        </div>
                        
                        <div class="col-md-4 text-center mb-3">
                            <div class="contact-info bg-light rounded p-4">
                                <i class="fa fa-2x fa-envelope text-primary mb-3"></i>
                                <h5><%= typeof t !== 'undefined' && t.contact ? t.contact.email : 'Email' %></h5>
                                <p class="mb-0"><%= companyInfo.email %></p>
                            </div>
                        </div>

                        <div class="col-md-4 text-center mb-3">
                            <div class="contact-info bg-light rounded p-4">
                                <i class="fa fa-2x fa-envelope text-primary mb-3"></i>
                                <h5><%= typeof t !== 'undefined' && t.contact ? t.contact.email : 'Email' %></h5>
                                <p class="mb-0"><%= companyInfo.email %></p>
                            </div>
                        </div>
                        
                    </div>

                    <div class="wow fadeIn" data-wow-delay="0.3s">
                        <form action="/contact/send" method="POST">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <div class="form-floating">
                                        <input type="text" class="form-control" id="name" name="name" 
                                               placeholder="<%= typeof t !== 'undefined' && t.contact ? t.contact.form.name : 'Votre Nom' %>" required>
                                        <label for="name"><%= typeof t !== 'undefined' && t.contact ? t.contact.form.name : 'Votre Nom' %></label>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-floating">
                                        <input type="email" class="form-control" id="email" name="email" 
                                               placeholder="<%= typeof t !== 'undefined' && t.contact ? t.contact.form.email : 'Votre Email' %>" required>
                                        <label for="email"><%= typeof t !== 'undefined' && t.contact ? t.contact.form.email : 'Votre Email' %></label>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-floating">
                                        <input type="tel" class="form-control" id="phone" name="phone" 
                                               placeholder="<%= typeof t !== 'undefined' && t.contact ? t.contact.form.phone : 'Votre Téléphone' %>">
                                        <label for="phone"><%= typeof t !== 'undefined' && t.contact ? t.contact.form.phone : 'Votre Téléphone' %></label>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-floating">
                                        <select class="form-select" id="service" name="service" required>
                                            <option value="" selected disabled><%= typeof t !== 'undefined' && t.contact ? t.contact.form.service : 'Type de Service' %></option>
                                            <option value="ssd"><%= typeof t !== 'undefined' && t.services ? t.services.additionalTitle1 : 'Solution SSD Universelle' %></option>
                                            <option value="machines"><%= typeof t !== 'undefined' && t.services ? t.services.additionalTitle2 : 'Location Machines' %></option>
                                            <option value="analysis"><%= typeof t !== 'undefined' && t.services ? t.services.additionalTitle3 : 'Analyse Spectrophotométrie' %></option>
                                            <option value="powder"><%= typeof t !== 'undefined' && t.services ? t.services.additionalTitle4 : 'Poudres d\'Activation' %></option>
                                            <option value="expertise">Expertise & Conseil</option>
                                            <option value="institution">Solutions Institutions</option>
                                        </select>
                                        <label for="service"><%= typeof t !== 'undefined' && t.contact ? t.contact.form.service : 'Type de Service' %></label>
                                    </div>
                                </div>
                                <div class="col-12">
                                    <div class="form-floating">
                                        <input type="text" class="form-control" id="subject" name="subject" 
                                               placeholder="<%= typeof t !== 'undefined' && t.contact ? t.contact.form.subject : 'Sujet' %>" required>
                                        <label for="subject"><%= typeof t !== 'undefined' && t.contact ? t.contact.form.subject : 'Sujet' %></label>
                                    </div>
                                </div>
                                <div class="col-12">
                                    <div class="form-floating">
                                        <textarea class="form-control" placeholder="<%= typeof t !== 'undefined' && t.contact ? t.contact.form.message : 'Décrivez votre besoin en détail...' %>" 
                                                  id="message" name="message" style="height: 150px" required></textarea>
                                        <label for="message"><%= typeof t !== 'undefined' && t.contact ? t.contact.form.message : 'Message' %></label>
                                    </div>
                                </div>
                                <div class="col-12">
                                    <button class="btn btn-primary w-100 py-3" type="submit">
                                        <i class="fa fa-paper-plane me-2"></i>
                                        <%= typeof t !== 'undefined' && t.contact ? t.contact.form.submit : 'Envoyer le Message' %>
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>

                    <!-- Contact rapide -->
                    <div class="text-center mt-5">
                        <h4 class="mb-3"><%= typeof t !== 'undefined' && t.contact ? t.contact.quickContact : 'Contact Rapide' %></h4>
                        <div class="d-flex justify-content-center gap-3 flex-wrap">
                            <a href="https://wa.me/<%= companyInfo.whatsapp %>?text=Bonjour%20Clean%20Laboratoire,%20je%20souhaite%20obtenir%20des%20informations%20sur%20vos%20services%20de%20nettoyage%20de%20billets." 
                               target="_blank" 
                               class="btn btn-success btn-lg">
                                <i class="fab fa-whatsapp me-2"></i>WhatsApp
                            </a>
                            <a href="tel:<%= companyInfo.phone %>" class="btn btn-primary btn-lg">
                                <i class="fa fa-phone me-2"></i><%= typeof t !== 'undefined' && t.contact ? t.contact.call : 'Appeler' %>
                            </a>
                            <a href="mailto:<%= companyInfo.email %>" class="btn btn-outline-primary btn-lg">
                                <i class="fa fa-envelope me-2"></i>Email
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Contact End -->

<style>
.contact-info {
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border: 1px solid #e9ecef;
}

.contact-info:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
}

.form-floating > .form-control:focus ~ label,
.form-floating > .form-control:not(:placeholder-shown) ~ label {
    color: #0d6efd;
}

.btn-success {
    background-color: #25D366;
    border-color: #25D366;
}

.btn-success:hover {
    background-color: #128C7E;
    border-color: #128C7E;
}
</style>

<%- include('partials/footer') %>