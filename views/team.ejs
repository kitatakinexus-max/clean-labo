<%- include('partials/header') %>

    <!-- Header Start -->
    <div class="container-fluid page-header py-5 mb-5">
        <div class="container py-5">
            <h1 class="display-3 text-white mb-3 animated slideInRight">
                <%= typeof t !== 'undefined' && t.team ? t.team.hero.title : 'Notre' %>
                <span class="text-primary">
                    <%= typeof t !== 'undefined' && t.team ? t.team.hero.titleHighlight : 'Équipe' %>
                </span>
            </h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb animated slideInRight">
                    <li class="breadcrumb-item"><a class="text-white" href="/?lang=<%= currentLang %>"> <%= typeof t !== 'undefined' && t.nav ? t.nav.home : 'Accueil' %></a></li>
                    <li class="breadcrumb-item text-primary" aria-current="page">
                        <%= typeof t !== 'undefined' && t.team ? t.team.hero.titleHighlight : 'Équipe' %>
                    </li>
                </ol>
            </nav>
            <p class="text-white mt-3">
                <%= typeof t !== 'undefined' && t.team ? t.team.hero.subtitle : 'Des experts qualifiés à votre service' %>
            </p>
        </div>
    </div>
    <!-- Header End -->

    <!-- Team Section Start -->
    <div class="container-fluid py-5">
        <div class="container">
            <div class="text-center mx-auto mb-5" style="max-width: 600px;">
                <h1 class="display-4 mb-4">
                    <%= typeof t !== 'undefined' && t.team ? t.team.hero.title : 'Notre' %>
                    <span class="text-primary">
                        <%= typeof t !== 'undefined' && t.team ? t.team.hero.titleHighlight : 'Équipe' %>
                    </span>
                </h1>
                <p class="mb-4">
                    <%= typeof t !== 'undefined' && t.team ? t.team.hero.subtitle : 'Des experts qualifiés à votre service' %>
                </p>
            </div>

            <div class="row g-4">
                <% if (typeof t !== 'undefined' && t.team && t.team.members && Array.isArray(t.team.members)) { %>
                    <% t.team.members.forEach(function(member, index) { %>
                        <div class="col-lg-3 col-md-6 wow fadeInUp" data-wow-delay="<%= 0.1 * (index + 1) %>s">
                            <div class="team-item">
                                <div class="position-relative overflow-hidden rounded">
                                    <img class="img-fluid w-100" src="<%= getAsset('/img/team-' + ((index % 4) + 1) + '.jpg') %>" alt="<%= member.name %>">
                                    <div class="team-overlay">
                                        <a class="btn btn-lg-square btn-primary rounded-circle mx-1" href="#"><i class="fab fa-facebook-f"></i></a>
                                        <a class="btn btn-lg-square btn-primary rounded-circle mx-1" href="#"><i class="fab fa-twitter"></i></a>
                                        <a class="btn btn-lg-square btn-primary rounded-circle mx-1" href="#"><i class="fab fa-linkedin-in"></i></a>
                                    </div>
                                </div>
                                <div class="border border-2 border-primary rounded p-4">
                                    <h4 class="mb-2"><%= member.name %></h4>
                                    <p class="text-primary mb-2"><%= member.role %></p>
                                    <p class="mb-0 small"><%= member.bio %></p>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                <% } else { %>
                    <!-- Fallback default team members -->
                    <div class="col-lg-3 col-md-6 wow fadeInUp" data-wow-delay="0.1s">
                        <div class="team-item">
                            <div class="position-relative overflow-hidden rounded">
                                <img class="img-fluid w-100" src="<%= getAsset('/img/team-1.jpg') %>" alt="Dr. Martin">
                                <div class="team-overlay">
                                    <a class="btn btn-lg-square btn-primary rounded-circle mx-1" href="#"><i class="fab fa-facebook-f"></i></a>
                                    <a class="btn btn-lg-square btn-primary rounded-circle mx-1" href="#"><i class="fab fa-twitter"></i></a>
                                    <a class="btn btn-lg-square btn-primary rounded-circle mx-1" href="#"><i class="fab fa-linkedin-in"></i></a>
                                </div>
                            </div>
                            <div class="border border-2 border-primary rounded p-4">
                                <h4 class="mb-2">Dr. Martin</h4>
                                <p class="text-primary mb-2">Directeur Scientifique</p>
                                <p class="mb-0 small">Expert en chimie analytique avec 15 ans d'expérience</p>
                            </div>
                        </div>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
    <!-- Team Section End -->

    <!-- CTA Section Start -->
    <div class="container-fluid py-5 bg-primary">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-7 text-center text-lg-start">
                    <h3 class="text-white mb-4">
                        <%= typeof t !== 'undefined' && t.team && t.team.cta ? t.team.cta.title : 'Rejoignez Notre Équipe' %>
                    </h3>
                    <p class="text-white mb-0">
                        <%= typeof t !== 'undefined' && t.team && t.team.cta ? t.team.cta.subtitle : 'Nous sommes toujours à la recherche de talents' %>
                    </p>
                </div>
                <div class="col-lg-5 text-center text-lg-end">
                    <a class="btn btn-outline-light btn-lg-rounded py-2 px-4" href="/contact?lang=<%= currentLang %>">
                        <%= typeof t !== 'undefined' && t.team && t.team.cta ? t.team.cta.button : 'Contactez-nous' %>
                    </a>
                </div>
            </div>
        </div>
    </div>
    <!-- CTA Section End -->

<%- include('partials/footer') %>
